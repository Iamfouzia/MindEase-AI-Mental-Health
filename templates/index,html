<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MindEase — AI Psychology Chatbot</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Sora', sans-serif; background: #07080f; color: #e8e6f0; min-height: 100vh; overflow-x: hidden; }

    /* Background floating orbs */
    .bg-orbs { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .orb { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.18; animation: float 8s ease-in-out infinite; }
    .orb1 { width: 500px; height: 500px; background: #7c5cbf; top: -120px; left: -100px; }
    .orb2 { width: 400px; height: 400px; background: #3d8fd4; top: 200px; right: -80px; animation-delay: 3s; }
    .orb3 { width: 300px; height: 300px; background: #c45fa0; bottom: 50px; left: 30%; animation-delay: 5s; }
    @keyframes float { 0%,100%{ transform: translateY(0); } 50%{ transform: translateY(-30px); } }

    /* Navbar */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 18px 40px; display: flex; align-items: center; justify-content: space-between; background: rgba(7,8,15,0.6); backdrop-filter: blur(20px); border-bottom: 0.5px solid rgba(255,255,255,0.08); }
    .logo { font-family: 'DM Serif Display', serif; font-size: 22px; background: linear-gradient(135deg, #b794f4, #76e4f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .logo em { font-style: italic; }
    .nav-links { display: flex; gap: 32px; }
    .nav-links a { font-size: 13px; color: rgba(232,230,240,0.6); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: #e8e6f0; }
    .nav-cta { background: rgba(180,120,255,0.15); border: 0.5px solid rgba(180,120,255,0.4); color: #c9a6ff; padding: 9px 22px; border-radius: 100px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'Sora', sans-serif; transition: background 0.2s; }
    .nav-cta:hover { background: rgba(180,120,255,0.28); }

    /* Hero section */
    .hero { position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120px 40px 60px; text-align: center; }

    /* Badge */
    .badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(124,92,191,0.18); border: 0.5px solid rgba(178,140,255,0.3); padding: 6px 16px; border-radius: 100px; font-size: 12px; color: #c9a6ff; font-weight: 500; margin-bottom: 32px; animation: fadeUp 0.6s ease both; }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #a78bfa; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

    /* Main heading */
    h1 { font-family: 'DM Serif Display', serif; font-size: clamp(40px, 7vw, 72px); line-height: 1.08; letter-spacing: -1.5px; color: #f0eef8; margin-bottom: 24px; animation: fadeUp 0.7s ease 0.1s both; }
    h1 em { font-style: italic; color: #b794f4; }

    /* Subtitle */
    .subtitle { font-size: 16px; color: rgba(232,230,240,0.55); font-weight: 300; max-width: 480px; line-height: 1.7; margin-bottom: 44px; animation: fadeUp 0.7s ease 0.2s both; }

    /* Hero buttons */
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; margin-bottom: 64px; animation: fadeUp 0.7s ease 0.3s both; }
    .btn-primary { background: linear-gradient(135deg, #7c5cbf, #5a89d8); color: #fff; border: none; padding: 14px 34px; border-radius: 100px; font-size: 14px; font-weight: 500; cursor: pointer; font-family: 'Sora', sans-serif; box-shadow: 0 8px 32px rgba(124,92,191,0.35); transition: opacity 0.2s, transform 0.2s; }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-ghost { background: rgba(255,255,255,0.05); color: rgba(232,230,240,0.75); border: 0.5px solid rgba(255,255,255,0.12); padding: 14px 28px; border-radius: 100px; font-size: 14px; cursor: pointer; font-family: 'Sora', sans-serif; transition: background 0.2s; }
    .btn-ghost:hover { background: rgba(255,255,255,0.1); }

    /* Chat preview box */
    .chat-preview { width: 100%; max-width: 620px; background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 24px; overflow: hidden; backdrop-filter: blur(12px); animation: fadeUp 0.8s ease 0.4s both; margin-bottom: 72px; }
    .chat-header { padding: 16px 22px; border-bottom: 0.5px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px; }
    .chat-avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #7c5cbf, #5a89d8); display: flex; align-items: center; justify-content: center; font-size: 15px; }
    .chat-status { font-size: 13px; font-weight: 500; }
    .chat-online { font-size: 11px; color: #7cba8a; display: flex; align-items: center; gap: 4px; }
    .online-dot { width: 5px; height: 5px; border-radius: 50%; background: #7cba8a; }
    .chat-body { padding: 20px 22px; display: flex; flex-direction: column; gap: 14px; }
    .msg { display: flex; gap: 10px; align-items: flex-end; }
    .msg.user, .msg.msg-user { flex-direction: row-reverse; }
    .msg-bubble { max-width: 78%; padding: 11px 16px; border-radius: 18px; font-size: 13px; line-height: 1.6; }
    .msg-ai .msg-bubble { background: rgba(255,255,255,0.07); color: rgba(232,230,240,0.85); border-bottom-left-radius: 4px; }
    .msg.msg-user .msg-bubble, .msg.user .msg-bubble { background: linear-gradient(135deg, #7c5cbf, #5a89d8) !important; color: #f0eef8 !important; border-radius: 18px !important; padding: 11px 16px !important; display: block !important; box-shadow: 0 4px 15px rgba(124,92,191,0.3) !important; }
    .msg-icon { width: 26px; height: 26px; border-radius: 50%; background: linear-gradient(135deg, #7c5cbf, #5a89d8); display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
    .emotion-chip { display: inline-flex; align-items: center; gap: 5px; background: rgba(124,92,191,0.2); border: 0.5px solid rgba(178,140,255,0.3); padding: 3px 10px; border-radius: 100px; font-size: 10px; color: #c9a6ff; margin-top: 6px; }
    .chat-input-row { padding: 14px 22px; border-top: 0.5px solid rgba(255,255,255,0.08); display: flex; gap: 10px; align-items: center; }
    .chat-input { flex: 1; background: rgba(255,255,255,0.06); border: 0.5px solid rgba(255,255,255,0.12); border-radius: 100px; padding: 10px 18px; font-size: 13px; color: rgba(232,230,240,0.5); font-family: 'Sora', sans-serif; outline: none; }
    .send-btn { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #7c5cbf, #5a89d8); border: none; cursor: pointer; color: white; font-size: 15px; display: flex; align-items: center; justify-content: center; }

    /* Feature cards */
    .features { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; padding: 0 40px 80px; max-width: 700px; margin: 0 auto; width: 100%; }
    .feat-card { background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 22px 18px; transition: border-color 0.2s, background 0.2s; animation: fadeUp 0.7s ease both; }
    .feat-card:hover { border-color: rgba(178,140,255,0.3); background: rgba(124,92,191,0.08); }
    .feat-icon { font-size: 22px; margin-bottom: 12px; background: linear-gradient(135deg, #b794f4, #76e4f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .feat-card h3 { font-size: 13px; font-weight: 500; margin-bottom: 6px; }
    .feat-card p { font-size: 12px; color: rgba(232,230,240,0.45); line-height: 1.6; }

    /* Sections shared style */
    .section { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; padding: 60px 40px; }
    .section h2 { font-family: 'DM Serif Display', serif; font-size: 32px; color: #f0eef8; margin-bottom: 10px; }
    .section h2 em { font-style: italic; color: #b794f4; }
    .section .sec-sub { font-size: 13px; color: rgba(232,230,240,0.5); margin-bottom: 32px; }

    /* How it works steps */
    .steps { display: flex; flex-direction: column; gap: 16px; }
    .step { background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 22px 24px; display: flex; gap: 16px; align-items: flex-start; transition: border-color 0.2s; }
    .step:hover { border-color: rgba(178,140,255,0.3); }
    .step-icon { font-size: 22px; }
    .step h3 { font-size: 14px; font-weight: 500; margin-bottom: 6px; }
    .step p { font-size: 12px; color: rgba(232,230,240,0.45); line-height: 1.6; }

    /* CBT grid */
    .cbt-box { background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 28px 24px; }
    .cbt-intro { font-size: 13px; color: rgba(232,230,240,0.7); line-height: 1.8; margin-bottom: 20px; }
    .cbt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .cbt-card { background: rgba(124,92,191,0.1); border: 0.5px solid rgba(178,140,255,0.2); border-radius: 12px; padding: 16px; }
    .cbt-card .icon { font-size: 18px; margin-bottom: 8px; }
    .cbt-card h4 { font-size: 12px; font-weight: 500; margin-bottom: 4px; }
    .cbt-card p { font-size: 11px; color: rgba(232,230,240,0.45); line-height: 1.6; }

    /* Resources links */
    .resource-links { display: flex; flex-direction: column; gap: 12px; }
    .resource-link { text-decoration: none; background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; transition: border-color 0.2s; }
    .resource-link:hover { border-color: rgba(178,140,255,0.3); }
    .resource-link h3 { font-size: 13px; font-weight: 500; color: #f0eef8; margin-bottom: 4px; }
    .resource-link p { font-size: 12px; color: rgba(232,230,240,0.45); }
    .resource-arrow { color: #b794f4; font-size: 16px; }

    /* Disclaimer */
    .disclaimer { position: relative; z-index: 1; text-align: center; font-size: 11px; color: rgba(232,230,240,0.25); padding-bottom: 40px; }

    /* Fade up animation */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>

  <!-- Floating background orbs -->
  <div class="bg-orbs">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
    <div class="orb orb3"></div>
  </div>

  <!-- Navbar — links scroll to sections -->
  <nav>
    <div class="logo">Mind<em>Ease</em></div>
    <div class="nav-links">
      <a href="#how-it-works">How it works</a>
      <a href="#about-cbt">About CBT</a>
      <a href="#resources">Resources</a>
    </div>
    <button class="nav-cta" onclick="window.location.href='/chat-page'">Start Free</button>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="badge">
      <div class="badge-dot"></div>
      AI Psychology Assistant — Always Available
    </div>

    <h1>Your safe space<br>to <em>heal &amp; grow</em></h1>

    <p class="subtitle">
      Talk to an empathetic AI trained in CBT principles.
      Understand your emotions, find your patterns, and feel calm — anytime.
    </p>

    <div class="hero-actions">
      <!-- Begin Journey button goes to chat page -->
      <button class="btn-primary" onclick="window.location.href='/chat-page'">Begin Your Journey →</button>
      <!-- See how it works scrolls down -->
      <button class="btn-ghost" onclick="document.getElementById('how-it-works').scrollIntoView({behavior:'smooth'})">See how it works</button>
    </div>

    <!-- Chat demo preview — static display only -->
    <div class="chat-preview">
      <div class="chat-header">
        <div class="chat-avatar">🌙</div>
        <div>
          <div class="chat-status">MindEase AI</div>
          <div class="chat-online"><div class="online-dot"></div> Here for you, always</div>
        </div>
      </div>
      <div class="chat-body">
        <div class="msg msg-user">
          <div class="msg-bubble">I've been feeling anxious lately, especially at night.</div>
        </div>
        <div class="msg msg-ai">
          <div class="msg-icon">🌿</div>
          <div>
            <div class="msg-bubble">I hear you — nighttime anxiety can feel overwhelming. Let's explore what's fueling those thoughts together, one step at a time. 💜</div>
            <div class="emotion-chip">🔍 Emotion detected: Anxiety · High</div>
          </div>
        </div>
      </div>
      <div class="chat-input-row">
        <input class="chat-input" id="homeInput" placeholder="Share what's on your mind...">
        <button class="send-btn" onclick="sendHome()">➤</button>
      </div>
      </div>
  </section>

  <script>
    // Send message from home page chat
    async function sendHome() {
      const input = document.getElementById('homeInput');
      const msg = input.value.trim();
      if (!msg) return;

      const box = document.querySelector('.chat-body');

      // Show user message with purple box
      box.innerHTML += `
        <div class="msg msg-user">
          <div class="msg-bubble">${msg}</div>
        </div>`;
      input.value = '';

      // Show typing indicator
      box.innerHTML += `
        <div class="msg msg-ai" id="homeTyping">
          <div class="msg-icon">🌿</div>
          <div><div class="msg-bubble" style="color:rgba(232,230,240,0.4)">Typing...</div></div>
        </div>`;

      // Call Flask API
      try {
        const res = await fetch('/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg })
        });
        const data = await res.json();

        // Remove typing indicator
        document.getElementById('homeTyping')?.remove();

        // Show AI reply
        box.innerHTML += `
          <div class="msg msg-ai">
            <div class="msg-icon">🌿</div>
            <div>
              <div class="msg-bubble">${data.reply}</div>
              ${data.emotion ? `<div class="emotion-chip">🌸 Emotion: ${data.emotion}</div>` : ''}
            </div>
          </div>`;

      } catch (err) {
        document.getElementById('homeTyping')?.remove();
        box.innerHTML += `
          <div class="msg msg-ai">
            <div class="msg-icon">🌿</div>
            <div><div class="msg-bubble">Something went wrong. Please try again. 💜</div></div>
          </div>`;
      }
    }

    // Send on Enter key
    document.getElementById('homeInput').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') sendHome();
    });
  </script>

  <!-- Feature cards -->
  <div class="features">
    <div class="feat-card" style="animation-delay:0.1s">
      <div class="feat-icon"><i class="ti ti-brain"></i></div>
      <h3>Emotion Detection</h3>
      <p>Real-time analysis of your emotional state on every message.</p>
    </div>
    <div class="feat-card" style="animation-delay:0.2s">
      <div class="feat-icon"><i class="ti ti-shield-heart"></i></div>
      <h3>Crisis Support</h3>
      <p>Instant safety response when distress keywords are detected.</p>
    </div>
    <div class="feat-card" style="animation-delay:0.3s">
      <div class="feat-icon"><i class="ti ti-messages"></i></div>
      <h3>CBT Guidance</h3>
      <p>Evidence-backed techniques woven naturally into every reply.</p>
    </div>
    <div class="feat-card" style="animation-delay:0.4s">
      <div class="feat-icon"><i class="ti ti-moon"></i></div>
      <h3>Always Available</h3>
      <p>3am panic? We're here. No appointments, no waitlists.</p>
    </div>
  </div>

  <!-- How it works section -->
  <section class="section" id="how-it-works">
    <h2>How it <em>works</em></h2>
    <p class="sec-sub">Simple, safe, and always here for you.</p>
    <div class="steps">
      <div class="step">
        <div class="step-icon">💬</div>
        <div>
          <h3>Start a conversation</h3>
          <p>Just type how you feel — no signup, no judgment. MindEase listens warmly.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-icon">🧠</div>
        <div>
          <h3>AI detects your emotion</h3>
          <p>Every message is analyzed in real-time to understand what you're truly feeling.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-icon">💙</div>
        <div>
          <h3>Get warm CBT-based reply</h3>
          <p>MindEase responds like a caring friend using proven CBT techniques naturally.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About CBT section -->
  <section class="section" id="about-cbt">
    <h2>About <em>CBT</em></h2>
    <p class="sec-sub">Cognitive Behavioural Therapy — the science behind MindEase.</p>
    <div class="cbt-box">
      <p class="cbt-intro">CBT is one of the most researched and effective forms of therapy. It helps you identify negative thought patterns and replace them with healthier ones.</p>
      <div class="cbt-grid">
        <div class="cbt-card">
          <div class="icon">🌿</div>
          <h4>Thought Reframing</h4>
          <p>Challenge and change unhelpful thinking patterns.</p>
        </div>
        <div class="cbt-card">
          <div class="icon">🧘</div>
          <h4>Breathing Techniques</h4>
          <p>Simple exercises to calm anxiety instantly.</p>
        </div>
        <div class="cbt-card">
          <div class="icon">📓</div>
          <h4>Journaling</h4>
          <p>Track emotions and spot patterns over time.</p>
        </div>
        <div class="cbt-card">
          <div class="icon">💪</div>
          <h4>Behavioural Activation</h4>
          <p>Small actions that break the cycle of low mood.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources section -->
  <section class="section" id="resources" style="padding-bottom:80px;">
    <h2>Helpful <em>Resources</em></h2>
    <p class="sec-sub">You are not alone — help is always available.</p>
    <div class="resource-links">
      <a href="https://www.befrienders.org" target="_blank" class="resource-link">
        <div><h3>🌍 Befrienders Worldwide</h3><p>International crisis support and listening service.</p></div>
        <span class="resource-arrow">→</span>
      </a>
      <a href="https://www.mind.org.uk" target="_blank" class="resource-link">
        <div><h3>🧠 Mind UK</h3><p>Mental health information, advice and support.</p></div>
        <span class="resource-arrow">→</span>
      </a>
      <a href="https://www.nimh.nih.gov" target="_blank" class="resource-link">
        <div><h3>🏥 NIMH</h3><p>National Institute of Mental Health — research and guides.</p></div>
        <span class="resource-arrow">→</span>
      </a>
      <a href="https://www.apa.org" target="_blank" class="resource-link">
        <div><h3>📚 APA</h3><p>American Psychological Association — trusted psychology resources.</p></div>
        <span class="resource-arrow">→</span>
        
      </a>
    <a href="https://umang.com.pk" target="_blank" class="resource-link">
        <div><h3>🇵🇰 Umang Pakistan</h3><p>Pakistan ka mental health helpline — 0317-4288665</p></div>
        <span class="resource-arrow">→</span>
      </a>
      <a href="https://rozan.org" target="_blank" class="resource-link">
        <div><h3>🇵🇰 Rozan Counseling</h3><p>Pakistan ki trusted mental health NGO aur counseling service.</p></div>
        <span class="resource-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Disclaimer -->
  <p class="disclaimer">
    MindEase is an AI assistant — not a replacement for professional mental health care.<br>
    If you're in crisis, please contact a licensed professional or helpline.
  </p>

</body>
</html>